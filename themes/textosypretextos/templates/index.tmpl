{% extends "base.tmpl" %}
{% from "macros.tmpl" import story_card with context %}

{% block meta_description %}Un weblog de {{ blog_author }}{% endblock %}
{% block og_description %}Un weblog de {{ blog_author }}{% endblock %}
{% block twitter_description %}Un weblog de {{ blog_author }}{% endblock %}

{% block content %}
  {#
    blog_posts, fotos_posts, videos_posts, de_otros_posts y popular_posts
    se inyectan desde conf.py vía GLOBAL_CONTEXT_FILLER.
    Reemplaza el uso de get_section() / get_page() de Zola.
  #}
  <main class="pt-8">
    <div class="home-grid">
      <section class="home-main">
        <div class="mb-6">
          <span class="section-ribbon">Últimos del blog</span>
        </div>

        {% if blog_posts %}
          {% set lead = blog_posts[0] %}
          <div class="home-lead editorial-rule">
            {{ story_card(lead, variant="feature") }}
          </div>

          {% if blog_posts | length > 1 %}
            <div class="home-blog-rest">
              {% for post in blog_posts %}
                {% if not loop.first %}
                  {{ story_card(post, variant="home-list") }}
                {% endif %}
              {% endfor %}
            </div>
          {% endif %}
        {% endif %}

        <div class="mt-12">
          <a class="more-link" href="/blog/">Ver más artículos del blog →</a>
        </div>
      </section>

      <aside class="home-sidebar">
        {% if fotos_posts %}
          <div class="sidebar-block">
            <div class="mb-4"><span class="section-ribbon">Foto</span></div>
            {{ story_card(fotos_posts[0], variant="compact") }}
          </div>
        {% endif %}

        {% if de_otros_posts %}
          <div class="sidebar-block">
            <div class="mb-4"><span class="section-ribbon">De otres</span></div>
            {{ story_card(de_otros_posts[0], variant="compact") }}
          </div>
        {% endif %}

        {% if videos_posts %}
          <div class="sidebar-block">
            <div class="mb-4"><span class="section-ribbon">Video</span></div>
            {{ story_card(videos_posts[0], variant="compact") }}
          </div>
        {% endif %}

        {% if popular_posts %}
          <div class="sidebar-block">
            <h2 class="module-title">Más leídos</h2>
            <div class="index-list">
              {% for post in popular_posts %}
                <article class="index-row">
                  <div class="feed-index">{% if loop.index < 10 %}0{% endif %}{{ loop.index }}</div>
                  <div>
                    {% set section_slug = post_section_slug(post) %}
                    <p class="story-kicker">{{ section_titles.get(section_slug, section_slug) }}</p>
                    <h3 class="story-title-xs"><a href="{{ post.permalink() }}">{{ post.title() }}</a></h3>
                  </div>
                </article>
              {% endfor %}
            </div>
          </div>
        {% endif %}
      </aside>
    </div>
  </main>
{% endblock %}

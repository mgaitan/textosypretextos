{# Shortcode: media_audio
   Uso: {{% media_audio src="/media/audio.mp3" title="Título" %}} #}
<figure class="align-center">
  <div class="border border-black p-4">
    {% if title %}
      <figcaption class="mb-3">{{ title }}</figcaption>
    {% endif %}
    <audio controls preload="none" class="w-full">
      <source src="{{ src }}">
    </audio>
  </div>
</figure>
